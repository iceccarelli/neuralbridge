# ─────────────────────────────────────────────────────────────
# NeuralBridge — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────
NEURALBRIDGE_ENV=development          # development | staging | production
NEURALBRIDGE_DEBUG=true
NEURALBRIDGE_HOST=0.0.0.0
NEURALBRIDGE_PORT=8000
NEURALBRIDGE_SECRET_KEY=change-me-to-a-random-64-char-string
NEURALBRIDGE_ENCRYPTION_KEY=          # Auto-generated on first run if empty

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://neuralbridge:neuralbridge@localhost:5432/neuralbridge
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ── Authentication ────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── OpenTelemetry ─────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=neuralbridge

# ── Adapter Credentials (examples) ───────────────────────────
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
SALESFORCE_INSTANCE_URL=

SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=

GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

SAP_HOST=
SAP_CLIENT=
SAP_USER=
SAP_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

AZURE_STORAGE_CONNECTION_STRING=

GCP_PROJECT_ID=
GCP_CREDENTIALS_PATH=

# ── CRA Compliance ────────────────────────────────────────────
CRA_ORGANIZATION_NAME=Your Organization
CRA_CONTACT_EMAIL=compliance@example.com
CRA_REPORTING_ENABLED=true

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_BURST=20

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
